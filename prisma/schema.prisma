generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Attempt {
  id          Int      @id @default(autoincrement())
  slug        String
  code        String
  passed      Boolean
  timeSpentMs Int
  createdAt   DateTime @default(now())
}

model ProblemProgress {
  slug       String   @id
  solved     Boolean  @default(false)
  bestTimeMs Int?
  updatedAt  DateTime @updatedAt
}
